{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://node.sentinelhost.qzz.io:2037/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "http://node.sentinelhost.qzz.io:2037/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
